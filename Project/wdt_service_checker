
module wdt_service_checker #(
    parameter COUNTER_WIDTH = 24
)(  input wire [31:0] max_service_count,
    input wire [31:0] min_service_count,
    input  wire                    clk,
    input  wire                    rst,
    input  wire                    enable,
    input  wire                    hb_pulse,
    input  wire [COUNTER_WIDTH-1:0] count_value,

    output reg                     service_ok_pulse,
    output reg                     early_fault_pulse,
    output reg                     late_fault_pulse
);

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            service_ok_pulse  <= 1'b0;
            early_fault_pulse <= 1'b0;
            late_fault_pulse  <= 1'b0;
        end else begin
            service_ok_pulse  <= 1'b0;
            early_fault_pulse <= 1'b0;
            late_fault_pulse  <= 1'b0;

            if (enable) begin
                if (hb_pulse) begin
                    if (count_value < min_service_count)
                        early_fault_pulse <= 1'b1;
                    else if (count_value <= max_service_count)
                        service_ok_pulse <= 1'b1;
                    else
                        late_fault_pulse <= 1'b1;
                end else if (count_value > max_service_count) begin
                    late_fault_pulse <= 1'b1;
                end
            end
        end
    end

endmodule
