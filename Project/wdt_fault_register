module wdt_fault_register (
    input  wire       clk,
    input  wire       rst,
    input  wire       clear_fault,
    input  wire       early_fault_pulse,
    input  wire       late_fault_pulse,

    output reg        fault_flag,
    output reg [1:0]  fault_code
);

    always @(posedge clk or posedge rst) begin
        if (rst) begin
            fault_flag <= 1'b0;
            fault_code <= 2'b00;
        end else if (clear_fault) begin
            fault_flag <= 1'b0;
            fault_code <= 2'b00;
        end else begin
            if (early_fault_pulse && late_fault_pulse) begin
                fault_flag <= 1'b1;
                fault_code <= 2'b11;
            end else if (early_fault_pulse) begin
                fault_flag <= 1'b1;
                fault_code <= 2'b01;
            end else if (late_fault_pulse) begin
                fault_flag <= 1'b1;
                fault_code <= 2'b10;
            end
        end
    end

endmodule
