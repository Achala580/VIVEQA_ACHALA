module wdt_window_counter #(
    parameter COUNTER_WIDTH = 24
)(
    input  wire                    clk,
    input  wire                    rst,
    input  wire                    enable,
    input  wire                    clear_count,
    output reg [COUNTER_WIDTH-1:0] count_value
);

    always @(posedge clk or posedge rst) begin
        if (rst)
            count_value <= {COUNTER_WIDTH{1'b0}};
        else if (!enable)
            count_value <= {COUNTER_WIDTH{1'b0}};
        else if (clear_count)
            count_value <= {COUNTER_WIDTH{1'b0}};
        else
            count_value <= count_value + 1'b1;
    end

endmodule
